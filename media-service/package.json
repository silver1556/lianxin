{
  "name": "lianxin-media-service",
  "version": "1.0.0",
  "description": "Media processing microservice for Lianxin social media platform",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "migrate:status": "sequelize db:migrate:status",
    "seed": "sequelize db:seed:all",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docker:build": "docker build -t lianxin-media-service .",
    "docker:run": "docker run -p 3002:3002 lianxin-media-service"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "axios": "^1.11.0",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "clamscan": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.15.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^21.0.0",
    "fs-extra": "^11.3.1",
    "get-video-duration": "^4.1.0",
    "heic-convert": "^2.1.0",
    "helmet": "^6.1.5",
    "image-size": "^1.0.2",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "moment": "^2.29.4",
    "multer": "^2.0.2",
    "mysql2": "^3.3.3",
    "probe-image-size": "^7.2.3",
    "sequelize": "^6.31.1",
    "sharp": "^0.34.3",
    "uuid": "^9.0.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "sequelize-cli": "^6.6.1",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "media-service",
    "image-processing",
    "video-processing",
    "microservice",
    "nodejs",
    "express",
    "sharp",
    "ffmpeg",
    "alibaba-cloud",
    "clamav"
  ],
  "author": "Lianxin Development Team",
  "license": "PROPRIETARY"
}
