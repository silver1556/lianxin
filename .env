# Lianxin Social Media Platform - Environment Configuration
# Copy this file to .env and update the values for your environment

# Application Environment
NODE_ENV=development

# PORTS
GATEWAY_PORT=3000
USER_SERVICE_PORT=3001

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key,X-Device-ID,X-App-Version
CORS_CREDENTIALS=true
CORS_MAX_AGE=3600

# API configuration
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME_USER_SERVICE=lianxin-user-service
DB_USER_USER_SERVICE=user
DB_PASSWORD_USER_SERVICE=Mahmud1334
MYSQL_ROOT_PASSWORD=Mahmud1334

DB_NAME_MEDIA_SERVICE=lianxin-media-service
DB_USER_MEDIA_SERVICE=user
DB_PASSWORD_MEDIA_SERVICE=Mahmud1334

# Database Pool Configuration
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_ACQUIRE_TIMEOUT=30000
DB_POOL_IDLE=10000
DB_LOGGING_ENABLED=false
DB_CONNECTION_TIMEOUT=60000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Mahmud1334@
REDIS_DB=0

# Redis Connection Settings
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3
REDIS_LAZY_CONNECT=false
REDIS_KEEP_ALIVE=30000
REDIS_ENABLE_OFFLINE_QUEUE=false

# Redis Logging
REDIS_LOGGING_ENABLED=true
REDIS_LOG_LEVEL=info

# Redis TLS (SSL) Configuration
REDIS_TLS_ENABLED=false
REDIS_TLS_CA=
REDIS_TLS_CERT=
REDIS_TLS_KEY=
REDIS_TLS_REJECT_UNAUTHORIZED=true

# Redis Cluster Configuration
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=localhost:6379,localhost:6380,localhost:6381
REDIS_CLUSTER_READY_CHECK=true
REDIS_CLUSTER_SCALE_READS=master
REDIS_CLUSTER_MAX_REDIRECTIONS=16
REDIS_CLUSTER_OFFLINE_QUEUE=true

# Redis Cache Settings
REDIS_KEY_PREFIX=lianxin:user:
REDIS_SESSION_TTL=604800
REDIS_OTP_TTL=300
REDIS_USER_PROFILE_TTL=3600
REDIS_SETTINGS_TTL=86400
REDIS_TOKEN_BLACKLIST_TTL=86400
REDIS_RATE_LIMIT_TTL=3600
REDIS_FRIEND_LIST_TTL=1800
REDIS_AVATAR_TTL=604800

# Redis Cache Strategies
REDIS_WRITE_THROUGH_ENABLED=true
REDIS_CACHE_ASIDE_ENABLED=true
REDIS_REFRESH_AHEAD_ENABLED=false

# Redis Compression
REDIS_COMPRESSION_ENABLED=false
REDIS_COMPRESSION_THRESHOLD=1024
REDIS_COMPRESSION_ALGORITHM=gzip

# Redis Serialization
REDIS_SERIALIZATION_FORMAT=json
REDIS_SERIALIZATION_ENCRYPTION=false
REDIS_ENCRYPTION_KEY=your-secret-encryption-key

# Redis Health Check
REDIS_HEALTH_CHECK_ENABLED=true
REDIS_HEALTH_CHECK_INTERVAL=30000
REDIS_HEALTH_CHECK_TIMEOUT=5000
REDIS_HEALTH_CHECK_RETRIES=3

# Redis Monitoring
REDIS_MONITORING_ENABLED=true
REDIS_METRICS_COLLECTION=true
REDIS_SLOW_LOG_ENABLED=true
REDIS_SLOW_LOG_THRESHOLD=100000

# Redis Performance Alerts
REDIS_ALERTS_ENABLED=true
REDIS_CONNECTION_ALERT_THRESHOLD=100
REDIS_MEMORY_ALERT_THRESHOLD=90
REDIS_LATENCY_ALERT_THRESHOLD=200

# JWT Configuration (Generate strong, random keys for production)
JWT_ACCESS_TOKEN_SECRET=super_secret_access_key_change_this_in_production_environment
JWT_REFRESH_TOKEN_SECRET=super_secret_refresh_key_change_this_in_production_environment
JWT_PASSWORD_RESET_TOKEN_SECRET=super_secret_password_reset_key_change_this_in_production
JWT_ACCESS_TOKEN_EXPIRY=7d
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=lianxin-user-service
JWT_AUDIENCE=lianxin-app
JWT_ENABLE_ROTATION=true
JWT_ROTATION_INTERVAL=86400000
JWT_ENABLE_BLACKLIST=true
JWT_BLACKLIST_CLEANUP_INTERVAL=3600000
JWT_CLOCK_TOLERANCE=30
JWT_MAX_TOKEN_AGE=86400000
JWT_ENABLE_PAYLOAD_ENCRYPTION=true
JWT_PAYLOAD_ENCRYPTION_KEY=f924ad22f7dbbb52b2a688ae51b13865b908d153d2604bcab991975675fb1497

# Encryption Configuration (Generate strong, random keys for production)
ENCRYPTION_PRIMARY_KEY=17fd29aced9622d002a77ef5b67e4d2c12e179828c452681d51cf8e34615b57b
ENCRYPTION_SECONDARY_KEY=ed2f701f51d9cd215b16235916d91466eac1c9f2bddadd23026249e4a3e36d87
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_LENGTH=32
ENCRYPTION_IV_LENGTH=16
ENCRYPTION_TAG_LENGTH=16
ENCRYPTION_ENABLE_KEY_ROTATION=true
ENCRYPTION_KEY_ROTATION_INTERVAL=2592000000
ENCRYPTION_ENABLE_HSM=true
HSM_ENDPOINT=your_hsm_endpoint
HSM_KEY_ID=your_hsm_key_id
HSM_REGION=your_hsm_region
ENCRYPTION_FIELDS=phone,first_name,last_name,birth_date,location,verification_data

# Password Security
PASSWORD_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_ENTROPY_MINIMUM=40
PASSWORD_RESET_TOKEN_EXPIRY=300000
PASSWORD_RESET_MAX_ATTEMPTS=3

# Session Configuration
SESSION_TIMEOUT=1800000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_VALIDATE_IP=true
SESSION_VALIDATE_USER_AGENT=true
SESSION_STORAGE_TYPE=redis
SESSION_ENCRYPT=true
SESSION_ENABLE_DEVICE_FINGERPRINTING=true
SESSION_DEVICE_TRUST_DURATION=2592000000
SESSION_REGENERATE_ON_LOGIN=true
SESSION_INVALIDATE_ON_LOGOUT=true
SESSION_ALLOW_CONCURRENT=true
SESSION_CONFLICT_RESOLUTION=lru 


# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_ALGORITHM=sha256
OTP_SECRET=0910b4f0b2222bf0689b42b06f8387ac3aa67d4430e3381c09558e7fd601ae8f
OTP_WINDOW=1
OTP_STORAGE_TYPE=redis
OTP_ENCRYPT=true
OTP_CLEANUP_INTERVAL=600000
OTP_ENABLE_SMS_THROTTLING=true
OTP_SMS_THROTTLE_WINDOW=60000
OTP_SMS_THROTTLE_MAX_REQUESTS=3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=1000
RATE_LIMIT_STORAGE_TYPE=redis
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_OTP_WINDOW_MS=300000
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=300000
RATE_LIMIT_PASSWORD_RESET_MAX=3


# Account Security
ACCOUNT_LOCKOUT_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_DELETION_GRACE_PERIOD_DAYS=15

# Alibaba Cloud SMS Configuration
ALIBABA_SMS_ACCESS_KEY_ID=your_alibaba_sms_access_key_id
ALIBABA_SMS_ACCESS_KEY_SECRET=your_alibaba_sms_access_key_secret
ALIBABA_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com
ALIBABA_SMS_REGION_ID=cn-hangzhou
ALIBABA_SMS_SIGN_NAME=Lianxin
ALIBABA_SMS_TEMPLATE_REGISTRATION=SMS_001
ALIBABA_SMS_TEMPLATE_LOGIN=SMS_002
ALIBABA_SMS_TEMPLATE_PASSWORD_RESET=SMS_003
ALIBABA_SMS_TEMPLATE_PHONE_CHANGE=SMS_004
ALIBABA_SMS_TEMPLATE_SECURITY_ALERT=SMS_005

# Cloud Storage Configuration (Alibaba OSS)
CLOUD_STORAGE_BASE_URL=https://cdn.lianxin.com
CLOUD_STORAGE_BUCKET=lianxin-assets
CLOUD_STORAGE_REGION=cn-hangzhou
CLOUD_STORAGE_ACCESS_KEY_ID=your_oss_access_key_id
CLOUD_STORAGE_ACCESS_KEY_SECRET=your_oss_access_key_secret

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Malware scan for file uploads
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=5000
CLAMAV_STRICT=true # set to false to skip scanning if clamd is down

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_DIR=./logs

# Security Headers
SECURITY_ENABLE_HSTS=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true
SECURITY_ENABLE_XSS_PROTECTION=true
SECURITY_ENABLE_NO_SNIFF=true
SECURITY_ENABLE_FRAME_GUARD=true
SECURITY_FRAME_GUARD_ACTION=deny
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

# Compliance Configuration
COMPLIANCE_ENABLE_PIPL=true
COMPLIANCE_ENABLE_CYBERSECURITY_LAW=true
COMPLIANCE_ENABLE_DATA_SECURITY_LAW=true
COMPLIANCE_DATA_RESIDENCY_REGION=cn-hangzhou
COMPLIANCE_ENABLE_REAL_NAME_VERIFICATION=true
COMPLIANCE_ENABLE_CONTENT_MODERATION=true
COMPLIANCE_ENABLE_GOVERNMENT_REPORTING=true
COMPLIANCE_GOVERNMENT_REPORTING_ENDPOINT=https://government-reporting.example.com

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_STORAGE_TYPE=database
AUDIT_RETENTION_DAYS=2555
AUDIT_ENCRYPT_LOGS=false
AUDIT_AUTHENTICATION=true
AUDIT_AUTHORIZATION=true
AUDIT_DATA_ACCESS=true
AUDIT_DATA_MODIFICATION=true
AUDIT_ADMIN_ACTIONS=true
AUDIT_SECURITY_EVENTS=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI=/csp-violation-report
CSP_REPORT_ONLY=true

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Phone Configuration
PHONE_DEFAULT_COUNTRY_CODE=+86
PHONE_SUPPORTED_COUNTRY_CODES=+86,+852,+853,+886

# External Services
USER_SERVICE_URL=http://localhost:3001
MEDIA_SERVICE_URL=http://localhost:3002

# Development Settings
ENABLE_SWAGGER=false
ENABLE_DEBUG_MODE=false
ENABLE_METRICS=true
METRICS_PORT=9090

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000