# ============================
# 1. Base image
# ============================
FROM node:20-alpine AS base
WORKDIR /app
COPY package*.json ./

# Install only production deps by default
RUN npm install --omit=dev

# ============================
# 2. Development image
# ============================
FROM node:20-alpine AS dev
WORKDIR /app

# Install dependencies (include dev for hot reload, migrations, linting, etc.)
COPY package*.json ./
RUN npm install

# Copy source
COPY . .

# Expose ports (API + Node debugger)
EXPOSE 3000 9229

# Use nodemon for auto-reload in dev
CMD ["npx", "nodemon", "--inspect=0.0.0.0:9229", "server.js"]

# ============================
# 3. Production image
# ============================
FROM node:20-alpine AS prod
WORKDIR /app

# Copy only production deps
COPY --from=base /app/node_modules ./node_modules

# Copy full source
COPY . .

# Expose app port
EXPOSE 3000

# Run app
CMD ["node", "server.js"]
